# Copy to .env.local and fill in your Supabase project values
# Get these from: https://supabase.com/dashboard → project → Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON=your-anon-public-key-here

# Without these the app runs in local-only mode (localStorage persistence)
# Add them when you're ready for Phase 2 (MCP + sync across devices)
